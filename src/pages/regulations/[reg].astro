---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAmendmentsForRegulation,
  sectionIdToParam,
} from "../../utils/cross-references";
import { url } from "../../utils/url";

export async function getStaticPaths() {
  const regs = await getCollection("regulations");
  return regs.map((entry) => ({
    params: { reg: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const amendments = await getAmendmentsForRegulation(entry.id);

const items = (await getCollection("regulationItems"))
  .filter((i) => i.id.startsWith(`${entry.id}/`))
  .sort((a, b) => {
    const [an, as] = parseKey(a.data.number);
    const [bn, bs] = parseKey(b.data.number);
    if (an !== bn) return an - bn;
    return as.localeCompare(bs);
  });

function parseKey(s: string): [number, string] {
  const m = s.match(/^([0-9]+)([A-Za-z]*)$/);
  if (!m) return [9999, s];
  return [parseInt(m[1], 10), m[2] || ""];
}

const groups = new Map<string, typeof items>();
for (const it of items) {
  const ch = it.data.chapter ?? "";
  const arr = groups.get(ch) ?? [];
  arr.push(it);
  groups.set(ch, arr);
}
const groupsArr = [...groups.entries()];
const hasChapters = groupsArr.length > 1 || (groupsArr.length === 1 && groupsArr[0][0] !== "");
---

<BaseLayout title={entry.data.title}>
  <article class="statute-prose">
    <p class="eyebrow"><a href={url("/regulations")}>UIDAI Regulations</a></p>
    <h1>{entry.data.title}</h1>
    <p class="metadata">
      <time datetime={entry.data.gazette_date.toISOString().slice(0, 10)}>
        {entry.data.gazette_date.toISOString().slice(0, 10)}
      </time>
      · <a href={entry.data.source_pdf_url}>Current consolidated PDF</a>
      {entry.data.original_pdf_url && (
        <>
          {" "}· <a href={entry.data.original_pdf_url} rel="external">
            As enacted{entry.data.original_as_of && (
              <> ({entry.data.original_as_of.toISOString().slice(0, 10)})</>
            )} ↗
          </a>
        </>
      )}
      · {items.length} regulation{items.length === 1 ? "" : "s"}
      {amendments.length > 0 && <> · {amendments.length} amending instrument{amendments.length === 1 ? "" : "s"}</>}
    </p>

    {entry.data.made_under_sections.length > 0 && (
      <p class="metadata">
        Made under section{entry.data.made_under_sections.length > 1 ? "s" : ""}:{" "}
        {entry.data.made_under_sections.map((s, i) => {
          const base = s.split("(")[0];
          return (
            <>
              {i > 0 && ", "}
              <a href={url(`/act/s/${sectionIdToParam("s-" + base.toLowerCase())}`)}>{s}</a>
            </>
          );
        })}
      </p>
    )}

    <h2>Arrangement of regulations</h2>
    {items.length === 0 ? (
      <p>No regulations have been ingested yet.</p>
    ) : hasChapters ? (
      groupsArr.map(([chapter, list]) => (
        <section class="arrangement-chapter">
          <h2>{chapter || "Unassigned"}</h2>
          <ul>
            {list.map((it) => (
              <li>
                <span class="sec-num">{it.data.number}.</span>
                <span class="sec-title">
                  <a href={url(`/regulations/${entry.id}/r/${it.data.number.toLowerCase()}`)}>
                    {it.data.title}
                  </a>
                </span>
                {it.data.status !== "original" && (
                  <span class={`sec-status ${it.data.status}`}>{it.data.status}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    ) : (
      <ul style="list-style:none; padding:0;">
        {items.map((it) => (
          <li style="display:grid; grid-template-columns:3rem 1fr auto; gap:0.85rem; padding:0.32rem 0; align-items:baseline;">
            <span class="sec-num" style="font-family:var(--font-sans); font-size:0.82rem; color:var(--color-ink-faint); font-variant-numeric:tabular-nums;">
              {it.data.number}.
            </span>
            <span>
              <a href={url(`/regulations/${entry.id}/r/${it.data.number.toLowerCase()}`)}>{it.data.title}</a>
            </span>
            {it.data.status !== "original" && (
              <span class={`sec-status ${it.data.status}`}>{it.data.status}</span>
            )}
          </li>
        ))}
      </ul>
    )}

    {amendments.length > 0 && (
      <section class="cross-ref">
        <h2>Amending instruments</h2>
        <ul class="instrument-list">
          {amendments.map((a) => (
            <li>
              <div class="instrument-title">
                <a href={url(`/regulations/${entry.id}/a/${a.data.gazette_date.toISOString().slice(0, 10)}`)}>
                  {a.data.title}
                </a>
              </div>
              <div class="instrument-meta">
                <time datetime={a.data.gazette_date.toISOString().slice(0, 10)}>
                  {a.data.gazette_date.toISOString().slice(0, 10)}
                </time>
                · <a href={a.data.source_pdf_url}>PDF</a>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
