---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { url } from "../../utils/url";

const rules = (await getCollection("rules")).sort(
  (a, b) => b.data.gazette_date.getTime() - a.data.gazette_date.getTime(),
);
---

<BaseLayout title="Rules">
  <article class="statute-prose">
    <p class="eyebrow">Made by the Central Government under section 55</p>
    <h1>Rules</h1>
    {rules.length === 0 ? (
      <p>No rules ingested yet.</p>
    ) : (
      <ul style="list-style:none; padding:0;">
        {rules.map((r) => (
          <li style="padding:0.6rem 0; border-bottom:1px solid var(--color-rule);">
            <div>
              <a href={url(`/rules/${r.id}`)}>{r.data.title}</a>
            </div>
            <div class="metadata" style="font-size:0.8rem; color:var(--color-ink-faint);">
              <time datetime={r.data.gazette_date.toISOString().slice(0, 10)}>
                {r.data.gazette_date.toISOString().slice(0, 10)}
              </time>
              {r.data.made_under_sections.length > 0 && (
                <span> · made under s. {r.data.made_under_sections.join(", ")}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>
