---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { url } from "../../utils/url";

const amendments = (await getCollection("amendments")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Amending Acts and Ordinances">
  <article class="statute-prose">
    <p class="eyebrow">Aadhaar Act, 2016</p>
    <h1>Amendments</h1>
    {amendments.length === 0 ? (
      <p>No amending instruments ingested yet.</p>
    ) : (
      <ul style="list-style:none; padding:0;">
        {amendments.map((a) => (
          <li style="padding:0.5rem 0; border-bottom:1px solid var(--color-rule);">
            <div>
              <a href={url(`/amendments/${a.id}`)}>{a.data.title}</a>
            </div>
            <div class="metadata" style="font-size:0.8rem; color:var(--color-ink-faint);">
              <time datetime={a.data.date.toISOString().slice(0, 10)}>
                {a.data.date.toISOString().slice(0, 10)}
              </time>
              · {a.data.kind}
            </div>
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>
